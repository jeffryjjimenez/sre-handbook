🔹 retry.sh
retry() {
  local retries=3
  local count=0

  until "$@"; do
    exit_code=$?
    count=$((count + 1))
    if [ $count -lt $retries ]; then
      sleep 2
    else
      return $exit_code
    fi
  done
}
🔹 service_health.sh
#!/bin/bash
set -euo pipefail

source ../utils/logging.sh

SERVICE="httpd"

if systemctl is-active --quiet $SERVICE; then
  log "$SERVICE is running"
else
  log "$SERVICE is down, restarting..."
  systemctl restart $SERVICE

  if systemctl is-active --quiet $SERVICE; then
    log "$SERVICE restarted successfully"
  else
    log "CRITICAL: Failed to restart $SERVICE"
  fi
fi
🔹 disk_monitor.sh
#!/bin/bash
source ../utils/logging.sh

THRESHOLD=80

df -h | awk 'NR>1 {print $5}' | cut -d% -f1 | while read usage
do
  if [ "$usage" -gt "$THRESHOLD" ]; then
    log "WARNING: Disk usage at $usage%"
  fi
done
🔹 log_watcher.sh
#!/bin/bash

LOG_FILE="/tmp/errors.log"

tail -Fn0 /var/log/messages | while read line
do
  if echo "$line" | grep -Ei "error|fail|critical"; then
    echo "$line" >> "$LOG_FILE"
  fi
done
🔹 auto_heal.sh (🔥 Interview Favorite)
#!/bin/bash
set -euo pipefail

source ../utils/logging.sh

SERVICE="httpd"

log "Checking service..."

if ! systemctl is-active --quiet $SERVICE; then
  log "Service down. Restarting..."
  systemctl restart $SERVICE

  if ! systemctl is-active --quiet $SERVICE; then
    log "CRITICAL: Restart failed"
  fi
fi
