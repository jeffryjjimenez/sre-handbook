🔹 deploy_web.sh
#!/bin/bash

set -e

PACKAGE="httpd wget unzip"
SERVICE="httpd"

yum install -y $PACKAGE &> /dev/null
systemctl enable --now $SERVICE

mkdir -p /tmp/web
cd /tmp/web

wget $1
unzip *.zip
cp -r * /var/www/html/

systemctl restart $SERVICE
