2. 🔐 Production Script Template (Golden Standard)
#!/bin/bash

set -euo pipefail

LOG_FILE="/var/log/script.log"

log() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') | $1" | tee -a "$LOG_FILE"
}

error_exit() {
  log "ERROR: $1"
  exit 1
}

trap 'error_exit "Script failed at line $LINENO"' ERR

✅ This gives you:

Fail-fast behavior
Logging
Debug visibility
Error tracing
3. 📦 Modular Script Design
Bad (Junior)
yum install httpd -y
systemctl start httpd
Good (Senior)
install_packages() {
  local packages="$1"
  yum install -y $packages &>> $LOG_FILE
}

manage_service() {
  local svc=$1
  systemctl enable --now $svc &>> $LOG_FILE
}
