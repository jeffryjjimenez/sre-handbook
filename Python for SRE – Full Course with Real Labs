Example: Monitor folder size

import os

def folder_size(path="."):
    total_size = 0
    for dirpath, dirnames, filenames in os.walk(path):
        for f in filenames:
            fp = os.path.join(dirpath, f)
            total_size += os.path.getsize(fp)
    return total_size

print(f"Total folder size: {folder_size('/var/log') / (1024*1024):.2f} MB")

Lab 3: Cleanup Old Log Files

import os
import time

def cleanup_logs(path="/var/log/myapp", days=7):
    now = time.time()
    for filename in os.listdir(path):
        filepath = os.path.join(path, filename)
        if os.path.isfile(filepath):
            file_age = (now - os.path.getmtime(filepath)) / (24*3600)
            if file_age > days:
                os.remove(filepath)
                print(f"Deleted: {filepath}")

cleanup_logs()

Explanation:
This lab teaches automation of log cleanup by deleting files older than 7 days.

Module 5: Exception Handling and Robust Scripts

Overview:
Handling exceptions ensures scripts run reliably in production.

Example: Monitor a web service

import requests

def check_service(url):
    try:
        response = requests.get(url, timeout=5)
        if response.status_code == 200:
            print(f"Service at {url} is up!")
        else:
            print(f"Service at {url} returned status {response.status_code}")
    except requests.exceptions.RequestException as e:
        print(f"Service at {url} is down! Error: {e}")

check_service("http://localhost:8080/health")

Lab 4: Safe Metrics Collector

import psutil

def get_cpu_percent():
    try:
        return psutil.cpu_percent(interval=1)
    except Exception as e:
        print(f"Failed to get CPU percent: {e}")
        return None

cpu = get_cpu_percent()
if cpu is not None and cpu > 90:
    print("ALERT: CPU usage above 90%")

Explanation:
Using try/except prevents crashes when metrics are temporarily unavailable.

