#!/bin/bash

echo "Please, enter your name: "
read name

echo "you entered $name , is it correct? (Y/N)"
read -n 1 confirm    # reads one caracter and saves it on confirm variable
echo
echo "Welcome $name "

Notes:

read -n 1 -s CONFIRMAR  # only allows 1 caracter and "s" is for silent, so it does not show in the screen what was typed.
echo -n "Please, enter your name: "  # here the -n is for not changing the line, so it is all in the same line.
read -p "Username: " USR    # "p" is for prompt. That is the same than:

echo -n "Username: "
read USR

read -sp "Password: " pass  # Prompt with silent output

Sample:

#!/bin/bash

read -p "Username: " user
read -sp "Password: " pass
echo
read -n 1 -s -p "Continue? (Y/N)" confirm
echo

echo "Welcome $user"


