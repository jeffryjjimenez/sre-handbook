🔁 38. Retry Logic
retry() {
  local retries=3
  local count=0

  until "$@"; do
    exit_code=$?
    count=$((count + 1))
    if [ $count -lt $retries ]; then
      sleep 2
    else
      return $exit_code
    fi
  done
}
