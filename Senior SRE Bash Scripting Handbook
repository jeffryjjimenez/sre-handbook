tar cvf /tmp/backup.tar /etc /var && \
gzip /tmp/backup.tar && \
scp /tmp/backup.tar.gz user@remote:/backup

With:

Creates a .tar archive of /etc and /var in /tmp
c = create, v = verbose, f = file

gzip /tmp/backup.tar : compress it to : /tmp/backup.tar.gz"

scp /tmp/backup.tar.gz user@remote:/backup   : Transfer it to a remote srver

command1 && command2 && command3 means Run next command ONLY if previous succeeded. So If any step fails, the next one won’t run

---

Advanced backup:

This script creates a timestamped compressed archive of user-level files (primarily $HOME),
stores it locally in /tmp, logs execution steps, and reports success or failure. It is designed
for lightweight automated backups (cron-ready) and does not include full system directories like /etc or /var.

#!/bin/bash

set -euo pipefail

BACKUP_DIR="/tmp"
TIMESTAMP=$(date +%F_%H-%M-%S)
BACKUP_FILE="$BACKUP_DIR/backup_$TIMESTAMP.tar.gz"

LOG_FILE="$HOME/backup.log"

log() {
  echo "$(date '+%F %T') - $1" | tee -a "$LOG_FILE"
}

error_exit() {
  log "ERROR: $1"
  exit 1
}

trap 'error_exit "Unexpected failure occurred."' ERR

log "Starting backup..."

# SAFE BACKUP (user-level only)
tar -czf "$BACKUP_FILE" "$HOME" 2>/dev/null || error_exit "Tar failed"

log "Backup created: $BACKUP_FILE"

log "Backup completed successfully"


