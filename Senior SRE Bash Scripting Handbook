#!/bin/bash

echo -ne "Enter a valid filename: "
read NAME

if [ -e "$NAME" ]; then
    echo "That file already exists"
else
    echo "Creating file $NAME"
    touch "$NAME"
    chmod 700 "$NAME"
    echo "The file has been created with rwx permissions for the user"
    echo "$(ls -l $NAME)"
fi

