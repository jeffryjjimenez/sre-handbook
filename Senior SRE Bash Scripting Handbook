🔁 38. Retry Logic

#!/bin/bash

retry() {                     # define a custom function (command) called retry
  local retries=3             # max number of attempts
  local count=0               # current attempt counter

  until "$@"; do              # run the passed command until it succeeds
    exit_code=$?              # get exit code of last command
    count=$((count + 1))      # increment attempt count
    echo "Attempt $count failed (exit code: $exit_code)" # log failure

    if [ $count -lt $retries ]; then  # if retries remain
      echo "Retrying in 2 seconds..." # inform retry
      sleep 2                         # wait before retry
    else
      echo "Command failed after $retries attempts" # final failure message
      return $exit_code               # return error and stop
    fi
  done
}

echo "Updating package list..."      # step 1 message
retry sudo apt update                # run command with retry logic

echo "Installing curl..."            # step 2 message
retry sudo apt install -y curl      # retry install if it fails

echo "Done ✅"                       # script completed

 

