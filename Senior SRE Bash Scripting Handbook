#!/bin/bash  

read -r -p "Name of script to create: " script_name  
# read input from user
# -p shows the prompt message
# -r prevents backslash interpretation (safer input handling)
# script_name is the variable where input is stored

if [[ -z "$script_name" ]]; then  
    # -z checks if the string is empty
    # if user just presses Enter, this condition is true

    echo "Error: script name cannot be empty"
    exit 1  # exit script with error
fi

touch "$script_name"  
# create empty file with that name

echo "#!/bin/bash" > "$script_name"  
# write shebang (overwrites file if exists)

echo "##### Automatically created script ###########" >> "$script_name"  
# append comment line

echo "pwd" >> "$script_name"  
# append a simple command (prints current directory)

chmod +x "$script_name"  
# make script executable

echo "Done. The script $script_name has been created and made executable."  
# confirmation message

