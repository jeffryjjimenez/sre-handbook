#!/bin/bash

read -p "Enter a valid filename: " NAME

if [ -e "$NAME" ]; then
    echo "That file already exists."

    read -n 1 -p "Do you want to delete it? (Y/N): " OPTION
    echo

    if [[ "$OPTION" == "Y" || "$OPTION" == "y" ]]; then
        rm -f "$NAME"
        echo "The file $NAME has been deleted."
    else
        echo "The file was not deleted."
    fi

else              # do this when the file does not exist
    echo "Creating file $NAME"
    touch "$NAME"
    chmod 700 "$NAME"
    echo "The file has been created with rwx permissions for the owner."
fi

