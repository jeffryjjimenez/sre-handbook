bash/advanced/auto_remediation.sh
#!/bin/bash
# Auto-remediation example: restart apache2 if CPU > 90%
CPU=$(top -bn1 | grep "Cpu(s)" | awk '{print $2 + $4}')
if (( ${CPU%.*} > 90 )); then
    echo "$(date): High CPU detected. Restarting apache2." >> /var/log/remediation.log
    systemctl restart apache2
fi
