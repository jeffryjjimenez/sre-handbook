#!/bin/bash
set -e
terraform plan -detailed-exitcode -out=/dev/null
EXIT_CODE=$?
if [ $EXIT_CODE -eq 2 ]; then
  echo "DRIFT DETECTED — sending alert"
  curl -X POST $SLACK_WEBHOOK_URL \
    -H "Content-Type: application/json" \
