- name: Copy file to remote hosts
  hosts: all
  become: true

  tasks:
    - name: Copy configuration file
      copy:
        src: /home/jeff/cc.cfg
        dest: /tmp/cc.cfg
        owner: jeff
        group: jeff
        mode: 0644
```

