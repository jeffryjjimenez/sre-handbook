# 25. Loops

```yaml
- name: Create users
  user:
    name: "{{ item }}"
    state: present
  loop:
    - jerry
    - kramer

Or:

---
- name: Install common packages
  hosts: all
  become: true

  tasks:

    - name: Install packages
      apt:
        name: "{{ item }}"
        state: present
        update_cache: yes
      loop:
        - curl
        - git
        - vim

Which do:

apt install curl
apt install git
apt install vim
```
Verify:

ansible all -a "which curl"
ansible all -a "which git"
ansible all -a "which vim"

--

ansible all -a "dpkg -s curl"  # -s for status
ansible all -a "dpkg -s git"
ansible all -a "dpkg -s vim"


Another example:

---
- name: Create users with different shells
  hosts: all
  become: true

  tasks:

    - name: Create users
      user:
        name: "{{ item.name }}"
        shell: "{{ item.shell }}"
        state: present
        create_home: true
      loop:
        - { name: jerry, shell: /bin/bash }
        - { name: kramer, shell: /bin/zsh }

