17. 📊 Disk Monitoring Script (Production Use)
usage=$(df -h | egrep -v "tmpfs|devtmpfs" | awk '{print $5}' | cut -d'%' -f1)

for i in $usage
do
  if [ $i -ge 80 ]; then
    echo "High disk usage: $i%"
  fi
done
18. 📜 Log Monitoring (REAL SRE USE CASE)
tail -fn0 /var/log/messages | while read line
do
  echo "$line" | egrep -i "error|fail|critical"
  if [ $? -eq 0 ]; then
    echo "$line" >> /tmp/errors.log
  fi
done
